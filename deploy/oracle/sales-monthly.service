[Unit]
Description=Sales Intelligence monthly report - auto generate all company insights + send summary
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/app
Environment=PATH=/home/ubuntu/app/venv/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=-/home/ubuntu/app/.env
ExecStart=/home/ubuntu/app/venv/bin/python reminder_worker.py monthly
TimeoutStartSec=600
