[Unit]
Description=Sales Intelligence mobile calendar API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/app
Environment=PATH=/home/ubuntu/app/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/ubuntu/app/venv/bin/uvicorn mobile_api:app --host 127.0.0.1 --port 8600
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
